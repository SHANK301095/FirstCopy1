# MMC Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env with real credentials

# ===========================================
# Frontend (Vite) Environment Variables
# ===========================================

# Supabase Project URL (required)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase Anon/Public Key (safe to expose in frontend)
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# Supabase Project ID
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ===========================================
# Backend (FastAPI) Environment Variables
# Set these in your hosting platform, not in .env
# ===========================================

# SUPABASE_JWT_SECRET - Required for production auth
# Get this from Supabase Dashboard > Project Settings > API > JWT Secret
# SUPABASE_JWT_SECRET="your-jwt-secret"

# Production mode flag (set to 1 in production)
# PRODUCTION="0"

# Development auth bypass (NEVER enable in production!)
# Only use for local development when JWT secret is not available
# DEV_AUTH_BYPASS="0"

# ===========================================
# Edge Functions Secrets
# These are set in Supabase/Lovable Cloud, not in .env
# ===========================================

# LOVABLE_API_KEY - Auto-provisioned by Lovable
# OPENAI_API_KEY - For AI features (optional)

# ===========================================
# IMPORTANT SECURITY NOTES
# ===========================================

# 1. NEVER commit .env with real values to git
# 2. In production, set PRODUCTION=1 to enforce strict auth
# 3. DEV_AUTH_BYPASS should NEVER be enabled in production
# 4. All sensitive keys should be set via hosting platform secrets
